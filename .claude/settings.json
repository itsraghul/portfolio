{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx next lint --file $CLAUDE_FILE_PATH --quiet 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo $CLAUDE_FILE_PATH | grep -q 'package-lock.json' && echo 'BLOCK: Do not edit lock files directly' && exit 1 || exit 0"
          }
        ]
      }
    ]
  }
}
